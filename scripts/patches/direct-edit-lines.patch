+import { describe, expect, test } from 'bun:test';
+import { changedLineEstimate } from '../../src/cli/editing/edit-session';
+
+describe('direct edit changed-line accounting', () => {
+  test('counts separated replacements without charging unchanged middle lines', () => {
+    const before = Array.from({ length: 700 }, (_, index) => `line-${index}`).join('\n');
+    const lines = before.split('\n');
+    lines[10] = 'line-10-updated';
+    lines[680] = 'line-680-updated';
+    expect(changedLineEstimate(before, lines.join('\n'))).toBe(2);
+  });
+
+  test('counts insertions and deletions by the larger actual diff side', () => {
+    expect(changedLineEstimate('a\nb\nc', 'a\ninserted\nb\nc')).toBe(1);
+    expect(changedLineEstimate('a\nb\nc', 'a\nc')).toBe(1);
+  });
+});
