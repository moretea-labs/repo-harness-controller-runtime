  "documents": {
    "spec": "docs/spec.md",
    "currentStatus": "tasks/current.md",
    "planDirectory": "plans",
    "deferredGoalLedger": "tasks/todos.md",
    "implementationNotesDirectory": "tasks/notes",
    "lessonsLog": "tasks/lessons.md",
    "researchReportsDirectory": "docs/researches"
  },
  "adoptionTemplates": {
    "files": {
      "spec": {
        "document": "spec",
        "reason": "Create deterministic product spec placeholder when missing",
        "lines": [
          "# Product Spec: {{repoName}}",
          "",
          "> **Status**: Draft",
          "",
          "Describe the product intent, users, workflows, acceptance scenarios, and constraints before implementation.",
          ""
        ]
      },
      "deferredGoalLedger": {
        "document": "deferredGoalLedger",
        "reason": "Create deferred-goal ledger when missing",
        "lines": [
          "# Deferred Goal Ledger",
          "",
          "> **Status**: Backlog",
          "> **Updated**: (initial)",
          "> **Scope**: Medium/long-term goals deferred from active plan execution",
          "",
          "Current plan tasks live in the active plan's `## Task Breakdown`.",
          "Do not duplicate that execution checklist here. Record only work intentionally deferred beyond this slice, with the tradeoff and revisit trigger.",
          "",
          "## Deferred Goals",
          "",
          "| Goal | Why Deferred | Tradeoff | Revisit Trigger |",
          "|------|--------------|----------|-----------------|",
          "| (none) | No deferred medium/long-term goal recorded yet. | Keep the first sprint bounded. | Add a row when a real follow-up is postponed. |",
          ""
        ]
      },
      "currentStatus": {
        "document": "currentStatus",
        "reason": "Create tracked current-status snapshot when missing",
        "lines": [
          "# Current Status Snapshot",
          "",
          "<!-- generated-by: repo-harness refresh-current-status v1 -->",
          "",
          "> **Status**: Idle",
          "> **Reason**: repo-harness adoption bootstrap",
          "",
          "This file is a tracked mainline snapshot derived from repo artifacts. It is not a live lock, not a kanban board, and not an implementation gate.",
          ""
        ]
      },
      "lessonsLog": {
        "document": "lessonsLog",
        "reason": "Create correction-derived lessons ledger when missing",
        "lines": [
          "# Lessons",
          "",
          "Correction-derived rules that should influence future repo work.",
          "",
          "## Active Lessons",
          "",
          "- (none yet)",
          ""
        ]
      }
    }
  },
  "migrations": {
    "legacyVersions": [
      "pre-tasks-first",
      "tasks-first-without-contract-manifest",
      "current-v1"
    ],
    "legacyPaths": [
      "docs/plan.md",
      "docs/TODO.md",
      "docs/PROGRESS.md",
      "docs/contract.md",
      "docs/review.md",
      "docs/handoff.md",
      "HANDOFF.md"
    ],
    "upgrade": {
      "strategyVersion": 1,
      "supportedLegacyVersions": [
        "pre-tasks-first",
        "tasks-first-without-contract-manifest",
        "current-v1"
      ],
      "actionClasses": [
        "preserve",
        "archive",
        "reconfigure",
        "remove"
      ],
      "safety": {
        "removeOnlyOwnership": "known_generated",
        "unknownFiles": "preserve-or-archive",
        "customHooks": "preserve",
        "ignoredReferenceMaterial": "preserve",
        "localSecrets": "preserve"
      },
      "actions": [
        {
          "id": "legacy-docs-plan",
          "signal": "legacy-docs-plan",
          "action": "archive",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            "docs/plan.md"
          ],
          "targetPaths": [
            "plans/archive/legacy-docs-plan.md"
          ],
          "summary": "Archive the legacy plan document before refreshing the tasks-first workflow."
        },
        {
          "id": "legacy-docs-todo",
          "signal": "legacy-docs-todo",
          "action": "archive",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            "docs/TODO.md"
          ],
          "targetPaths": [
            "tasks/archive/legacy-docs-TODO.md"
          ],
          "summary": "Archive the legacy checklist before writing the active task projection."
        },
        {
          "id": "legacy-docs-progress",
          "signal": "legacy-docs-progress",
          "action": "archive",
          "risk": "medium",
          "ownership": "user_authored",
          "paths": [
            "docs/PROGRESS.md"
          ],
          "targetPaths": [
            "docs/researches/legacy-progress-import.md",
            "tasks/archive/legacy-docs-PROGRESS.md"
          ],
          "summary": "Move execution-log style progress content into research reports and archive surfaces."
        },
        {
          "id": "legacy-singular-todo-file",
          "signal": "legacy-singular-todo-file",
          "action": "archive",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            "tasks/todo.md"
          ],
          "targetPaths": [
            "tasks/todos.md",
            "tasks/archive/legacy-tasks-todo.md"
          ],
          "summary": "Archive the legacy singular todo ledger and normalize the canonical deferred-goal ledger to tasks/todos.md."
        },
        {
          "id": "legacy-task-checklist-format",
          "signal": "legacy-task-checklist-format",
          "action": "archive",
          "risk": "medium",
          "ownership": "user_authored",
          "paths": [
            "tasks/todos.md"
          ],
          "targetPaths": [
            "tasks/archive/legacy-tasks-todo.md"
          ],
          "summary": "Archive old task checklists before rewriting tasks/todos.md as the active execution projection."
        },
        {
          "id": "legacy-task-sprint-prds",
          "signal": "legacy-task-sprint-prds",
          "action": "reconfigure",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            "tasks/sprints/*.sprint.md"
          ],
          "targetPaths": [
            "plans/sprints/*.sprint.md"
          ],
          "summary": "Move sprint backlog files out of tasks/ and into the sprint catalog under plans/sprints/; keep plans/prds/ for upper-layer PRDs."
        },
        {
          "id": "runtime-contract-refresh",
          "signal": "missing-runtime-contract-manifest",
          "action": "reconfigure",
          "risk": "low",
          "ownership": "managed_config",
          "paths": [
            ".ai/harness/workflow-contract.json",
            ".ai/harness/policy.json",
            ".ai/context/context-map.json"
          ],
          "summary": "Install the current runtime workflow contract, harness policy, and context map."
        },
        {
          "id": "policy-upgrade-strategy-refresh",
          "signal": "policy-missing-upgrade-strategy",
          "action": "reconfigure",
          "risk": "low",
          "ownership": "managed_config",
          "paths": [
            ".ai/harness/policy.json"
          ],
          "summary": "Merge the versioned upgrade strategy into the harness policy without overwriting explicit repo overrides."
        },
        {
          "id": "legacy-root-helper-runtime",
          "signal": "legacy-root-helper-runtime",
          "action": "remove",
          "risk": "medium",
          "ownership": "known_generated",
          "cleanupMode": "generated_helper",
          "paths": [
            "scripts/architecture-drift.sh",
            "scripts/architecture-event.ts",
            "scripts/architecture-queue.sh",
            "scripts/archive-architecture-request.sh",
            "scripts/archive-workflow.sh",
            "scripts/capability-config.ts",
            "scripts/capability-resolver.ts",
            "scripts/capture-plan.sh",
            "scripts/check-agent-tooling.sh",
            "scripts/check-architecture-sync.sh",
            "scripts/check-brain-manifest.sh",
            "scripts/check-context-files.sh",
            "scripts/check-deploy-sql-order.sh",
            "scripts/check-skill-version.ts",
            "scripts/check-task-sync.sh",
            "scripts/check-task-workflow.sh",
            "scripts/codex-handoff-resume.sh",
            "scripts/context-contract-sync.sh",
            "scripts/contract-run.ts",
            "scripts/contract-worktree.sh",
            "scripts/ensure-task-workflow.sh",
            "scripts/heartbeat-triage.sh",
            "scripts/inspect-project-state.ts",
            "scripts/maintenance-triage.sh",
            "scripts/migrate-project-template.sh",
            "scripts/migrate-workflow-docs.ts",
            "scripts/new-plan.sh",
            "scripts/new-spec.sh",
            "scripts/new-sprint.sh",
            "scripts/plan-to-todo.sh",
            "scripts/prepare-codex-handoff.sh",
            "scripts/prepare-handoff.sh",
            "scripts/refresh-current-status.sh",
            "scripts/select-agent-context-blocks.sh",
            "scripts/ship-worktrees.sh",
            "scripts/skill-factory-check.sh",
            "scripts/skill-factory-create.sh",
            "scripts/sprint-backlog.sh",
            "scripts/summarize-failures.sh",
            "scripts/switch-plan.sh",
            "scripts/sync-brain-docs.sh",
            "scripts/verify-contract.sh",
            "scripts/verify-sprint.sh",
            "scripts/workflow-contract.ts",
            "scripts/workstream-sync.sh"
          ],
          "summary": "Remove legacy repo-harness helper scripts from root scripts/ only when file content is identifiable as generated repo-harness runtime; preserve ambiguous app-owned scripts."
        },
        {
          "id": "legacy-skill-factory-generated-assets",
          "signal": "legacy-skill-factory-surface",
          "action": "remove",
          "risk": "medium",
          "ownership": "known_generated",
          "paths": [
            ".ai/hooks/lib/memory-state.sh",
            ".ai/hooks/lib/skill-factory.sh",
            ".ai/hooks/memory-intake.sh",
            ".ai/hooks/skill-factory-session-end.sh",
            ".claude/skill-factory",
            ".claude/.memory-context.json",
            ".claude/.memory-snapshot.json",
            ".claude/.skill-factory-state.json",
            ".claude/.skill-factory-session.json",
            ".claude/.skill-factory-session-marker.json",
            ".claude/.skill-factory-user"
          ],
          "summary": "Remove repo-local Skill Factory and auto-memory files that were generated by retired workflow versions."
        },
        {
          "id": "legacy-claude-hook-shims",
          "signal": "stale-generated-claude-hook-shims",
          "action": "remove",
          "risk": "medium",
          "ownership": "known_generated",
          "paths": [
            ".claude/hooks/anti-simplification.sh",
            ".claude/hooks/atomic-commit.sh",
            ".claude/hooks/atomic-pending.sh",
            ".claude/hooks/changelog-guard.sh",
            ".claude/hooks/context-pressure-hook.sh",
            ".claude/hooks/finalize-handoff.sh",
            ".claude/hooks/hook-input.sh",
            ".claude/hooks/lib/memory-state.sh",
            ".claude/hooks/lib/session-state.sh",
            ".claude/hooks/lib/skill-factory.sh",
            ".claude/hooks/lib/workflow-state.sh",
            ".claude/hooks/memory-intake.sh",
            ".claude/hooks/post-bash.sh",
            ".claude/hooks/post-edit-guard.sh",
            ".claude/hooks/pre-code-change.sh",
            ".claude/hooks/pre-edit-guard.sh",
            ".claude/hooks/prompt-guard.sh",
            ".claude/hooks/run-hook.sh",
            ".claude/hooks/session-start-context.sh",
            ".claude/hooks/skill-factory-session-end.sh",
            ".claude/hooks/tdd-guard-hook.sh",
            ".claude/hooks/trace-event.sh",
            ".claude/hooks/worktree-guard.sh"
          ],
          "summary": "Remove generated Claude hook shims after .ai/hooks becomes the shared hook implementation layer."
        },
        {
          "id": "split-post-tool-observer-hooks",
          "signal": "stale-split-post-tool-hooks",
          "action": "remove",
          "risk": "low",
          "ownership": "known_generated",
          "paths": [
            ".ai/hooks/trace-event.sh",
            ".ai/hooks/context-pressure-hook.sh"
          ],
          "summary": "Remove the split PostToolUse observer hooks replaced by the merged post-tool-observer.sh."
        },
        {
          "id": "legacy-architecture-drift-helper",
          "signal": "stale-architecture-drift-helper",
          "action": "remove",
          "risk": "low",
          "ownership": "known_generated",
          "paths": [
            "assets/templates/helpers/architecture-drift.sh"
          ],
          "summary": "Remove the retired architecture-drift helper after architecture-queue.sh absorbs request, card, index, and gate ownership."
        },
        {
          "id": "custom-claude-hooks-preserve",
          "signal": "custom-claude-hooks",
          "action": "preserve",
          "risk": "low",
          "ownership": "user_authored",
          "paths": [
            ".claude/hooks/custom-*.sh"
          ],
          "summary": "Preserve user-owned Claude hook scripts and keep them merged through .claude/settings.json."
        },
        {
          "id": "reference-and-secret-surfaces-preserve",
          "signal": "ignored-reference-or-secret-surfaces",
          "action": "preserve",
          "risk": "high",
          "ownership": "user_local",
          "paths": [
            "_ref/",
            ".codegraph/",
            "_ops/"
          ],
          "summary": "Never migrate, delete, or vendor ignored external references, local CodeGraph indexes, private operations state, secrets, or local environment values."
        },
        {
          "id": "legacy-tasks-research-notes",
          "signal": "legacy-tasks-research-notes",
          "action": "archive",
          "risk": "medium",
          "ownership": "user_authored",
          "paths": [
            "tasks/research.md"
          ],
          "targetPaths": [
            "docs/researches/legacy-research-notes.md"
          ],
          "summary": "Archive legacy singleton research notes into the docs/researches report surface and leave a tombstone pointer."
        }
      ]
    }
  }
}
