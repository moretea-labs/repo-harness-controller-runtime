{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "initializer-question-pack.v3.schema.json",
  "type": "object",
  "required": [
    "version",
    "goal",
    "decisionPoints",
    "planTiers",
    "inferredDefaults",
    "runtimeProfiles",
    "orchestrationProfiles",
    "evaluationProfiles",
    "handoffProfiles",
    "recoveryProfiles",
    "stateProfiles"
  ],
  "properties": {
    "version": {
      "const": "initializer-question-pack.v3"
    },
    "goal": {
      "type": "string"
    },
    "decisionPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "batch", "questions", "required"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "batch": { "type": "integer", "minimum": 1 },
          "questions": { "type": "array", "items": { "type": "string" } },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "planTiers": {
      "type": "object",
      "required": ["core", "presets"],
      "properties": {
        "core": { "type": "array", "items": { "type": "string" } },
        "presets": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "inferredDefaults": {
      "type": "object",
      "required": [
        "packageManagerPriority",
        "runtimeProfile",
        "orchestrationProfile",
        "evaluationProfile",
        "handoffProfile",
        "recoveryProfile",
        "stateProfile"
      ],
      "properties": {
        "packageManagerPriority": { "type": "array", "items": { "type": "string" } },
        "runtimeProfile": { "type": "string" },
        "orchestrationProfile": { "type": "string" },
        "evaluationProfile": { "type": "string" },
        "handoffProfile": { "type": "string" },
        "recoveryProfile": { "type": "string" },
        "stateProfile": { "type": "string" }
      },
      "additionalProperties": false
    },
    "runtimeProfiles": {
      "type": "object"
    },
    "orchestrationProfiles": {
      "type": "object"
    },
    "evaluationProfiles": {
      "type": "object"
    },
    "handoffProfiles": {
      "type": "object"
    },
    "recoveryProfiles": {
      "type": "object"
    },
    "stateProfiles": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
