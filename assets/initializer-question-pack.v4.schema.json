{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "initializer-question-pack.v4.schema.json",
  "type": "object",
  "required": [
    "version",
    "goal",
    "decisionPoints",
    "planTiers",
    "inferredDefaults",
    "runtimeProfiles",
    "orchestrationProfiles",
    "evaluationProfiles",
    "handoffProfiles",
    "recoveryProfiles",
    "stateProfiles",
    "contextProfiles",
    "webappRenderingModels",
    "aiNativeProfiles"
  ],
  "properties": {
    "version": {
      "const": "initializer-question-pack.v4"
    },
    "goal": {
      "type": "string"
    },
    "decisionPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "batch", "questions", "required"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "batch": { "type": "integer", "minimum": 1 },
          "questions": { "type": "array", "items": { "type": "string" } },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "planTiers": {
      "type": "object",
      "required": ["core", "presets"],
      "properties": {
        "core": { "type": "array", "items": { "type": "string" } },
        "presets": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "inferredDefaults": {
      "type": "object",
      "required": [
        "packageManagerPriority",
        "runtimeProfile",
        "orchestrationProfile",
        "evaluationProfile",
        "handoffProfile",
        "recoveryProfile",
        "stateProfile",
        "contextProfile",
        "aiNativeProfile",
        "webappRenderingModel"
      ],
      "properties": {
        "packageManagerPriority": { "type": "array", "items": { "type": "string" } },
        "runtimeProfile": { "type": "string" },
        "orchestrationProfile": { "type": "string" },
        "evaluationProfile": { "type": "string" },
        "handoffProfile": { "type": "string" },
        "recoveryProfile": { "type": "string" },
        "stateProfile": { "type": "string" },
        "contextProfile": { "type": "string" },
        "documentationProfile": { "type": "string" },
        "aiNativeProfile": { "type": "string" },
        "webappRenderingModel": { "type": "string" }
      },
      "additionalProperties": false
    },
    "runtimeProfiles": {
      "type": "object"
    },
    "orchestrationProfiles": {
      "type": "object"
    },
    "evaluationProfiles": {
      "type": "object"
    },
    "handoffProfiles": {
      "type": "object"
    },
    "recoveryProfiles": {
      "type": "object"
    },
    "stateProfiles": {
      "type": "object"
    },
    "contextProfiles": {
      "type": "object"
    },
    "webappRenderingModels": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "label",
          "description",
          "frontend",
          "deployment",
          "publicRoute",
          "appRoute",
          "fallback"
        ],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" },
          "frontend": { "type": "string" },
          "deployment": { "type": "string" },
          "publicRoute": { "type": "string" },
          "appRoute": { "type": "string" },
          "fallback": { "type": "string" },
          "projectStructureFile": { "type": "string" },
          "techStackRows": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "aiNativeProfiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "label",
          "description",
          "frontend",
          "runtimeProtocol",
          "backend",
          "stateDefault",
          "sidecarPolicy",
          "uiSchema"
        ],
        "properties": {
          "label": { "type": "string" },
          "description": { "type": "string" },
          "frontend": { "type": "string" },
          "runtimeProtocol": { "type": "string" },
          "backend": { "type": "string" },
          "stateDefault": { "type": "string" },
          "sidecarPolicy": { "type": "string" },
          "uiSchema": { "type": "string" },
          "projectStructureFile": { "type": "string" },
          "techStackRows": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
