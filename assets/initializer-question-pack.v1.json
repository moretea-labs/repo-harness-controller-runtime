{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "version": "initializer-question-pack.v1",
  "goal": "Infer strong defaults first, then batch confirm and override.",
  "decisionPoints": [
    {
      "id": "project_identity",
      "title": "Project Identity",
      "batch": 1,
      "questions": [
        "Project name",
        "Developer name",
        "One-line product brief"
      ],
      "required": true
    },
    {
      "id": "plan_selection",
      "title": "Plan Selection",
      "batch": 1,
      "questions": [
        "Choose core plan A-F or Custom Presets",
        "If Custom Presets: choose G/H/I/J/K"
      ],
      "required": true
    },
    {
      "id": "delivery_constraints",
      "title": "Delivery Constraints",
      "batch": 2,
      "questions": [
        "Team size",
        "MVP scope and acceptance criteria"
      ],
      "required": true
    },
    {
      "id": "runtime_defaults",
      "title": "Runtime Defaults",
      "batch": 2,
      "questions": [
        "Confirm inferred package manager",
        "Permission mode: Permissionless / Plan-only / Standard (default: Plan-only)",
        "Confirm commit policy"
      ],
      "required": true
    },
    {
      "id": "plan_overrides",
      "title": "Plan Overrides",
      "batch": 3,
      "questions": [
        "UI library",
        "State management",
        "Backend provider"
      ],
      "required": false
    },
    {
      "id": "quality_rules",
      "title": "Quality Rules",
      "batch": 3,
      "questions": [
        "Project-specific prohibitions",
        "Any must-enforce compliance constraints"
      ],
      "required": false
    },
    {
      "id": "plugin_profile",
      "title": "Plugin Profile",
      "batch": 4,
      "questions": [
        "Install recommended global plugins",
        "Enable LSP set by stack"
      ],
      "required": false
    },
    {
      "id": "hook_profile",
      "title": "Hook Profile",
      "batch": 4,
      "questions": [
        "Choose hooks preset A-F",
        "Any local hook customization"
      ],
      "required": false
    }
  ],
  "planTiers": {
    "core": [
      "A",
      "B",
      "C",
      "D",
      "E",
      "F"
    ],
    "presets": [
      "G",
      "H",
      "I",
      "J",
      "K"
    ]
  },
  "inferredDefaults": {
    "packageManagerPriority": [
      "bun",
      "pnpm",
      "npm"
    ],
    "runtimeProfile": "Plan-only"
  },
  "runtimeProfiles": {
    "permissionless": {
      "label": "Plan + Permissionless",
      "claudePolicy": "--dangerously-skip-permissions",
      "codexPolicy": "sandbox_mode=danger-full-access, approval_policy=never"
    },
    "plan-only": {
      "label": "Plan-only (recommended)",
      "claudePolicy": "(default permissions)",
      "codexPolicy": "sandbox_mode=platform-default, approval_policy=on-failure"
    },
    "standard": {
      "label": "Standard (ask before each action)",
      "claudePolicy": "(default permissions)",
      "codexPolicy": "sandbox_mode=platform-default, approval_policy=always"
    }
  }
}
