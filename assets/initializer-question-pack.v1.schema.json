{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "initializer-question-pack.v1.schema.json",
  "type": "object",
  "required": ["version", "goal", "decisionPoints", "planTiers", "inferredDefaults"],
  "properties": {
    "version": {
      "const": "initializer-question-pack.v1"
    },
    "goal": { "type": "string" },
    "decisionPoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "batch", "questions", "required"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "batch": { "type": "integer", "minimum": 1 },
          "questions": { "type": "array", "items": { "type": "string" } },
          "required": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "planTiers": {
      "type": "object",
      "required": ["core", "presets"],
      "properties": {
        "core": { "type": "array", "items": { "type": "string" } },
        "presets": { "type": "array", "items": { "type": "string" } }
      }
    },
    "inferredDefaults": {
      "type": "object",
      "required": ["packageManagerPriority", "runtimeProfile", "codexPolicy", "claudePolicy"],
      "properties": {
        "packageManagerPriority": { "type": "array", "items": { "type": "string" } },
        "runtimeProfile": { "type": "string" },
        "codexPolicy": { "type": "string" },
        "claudePolicy": { "type": "string" }
      }
    }
  }
}
