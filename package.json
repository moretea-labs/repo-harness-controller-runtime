{
  "name": "repo-harness",
  "version": "1.4.0",
  "description": "Installs, migrates, audits, and repairs repo-local agentic development harnesses",
  "license": "MIT",
  "author": "greysonOuyang",
  "homepage": "https://github.com/greysonOuyang/repo-harness-controller-runtime#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/greysonOuyang/repo-harness-controller-runtime.git"
  },
  "bugs": {
    "url": "https://github.com/greysonOuyang/repo-harness-controller-runtime/issues"
  },
  "type": "module",
  "files": [
    "NOTICE",
    ".agents/skills/repo-harness-chatgpt-browser/",
    "scripts/verify-controller-v8.sh",
    ".agents/skills/repo-harness-chatgpt-bridge/",
    "agents/",
    "assets/",
    "docs/images/",
    "docs/architecture/",
    "docs/operations/",
    "docs/public-usage-guide.md",
    "docs/public-usage-guide.zh-CN.md",
    "docs/repo-harness-chatgpt-browser-engine.md",
    "docs/repo-harness-chatgpt-controller.md",
    "docs/repo-harness-chatgpt-supervised-automation.md",
    "docs/repo-harness-chatgpt-mcp-setup.md",
    "docs/repo-harness-github-issue-launcher.md",
    "docs/repo-harness-local-execution-bridge.md",
    "docs/repo-harness-runtime-self-healing-loop.md",
    "docs/repo-harness-autonomous-goal-loop.md",
    "README.zh-CN.md",
    "install.sh",
    "install.ps1",
    "bin/",
    "scripts/",
    "src/",
    "AGENTS.md",
    "CLAUDE.md",
    "SKILL.md",
    "README.md",
    "ARCHITECTURE_MIGRATION_REPORT.md",
    "OPTIMIZATION_REPORT.md"
  ],
  "bin": {
    "repo-harness": "bin/repo-harness.mjs",
    "repo-harness-hook": "bin/repo-harness-hook.mjs"
  },
  "engines": {
    "node": ">=20.10.0",
    "bun": ">=1.0.0"
  },
  "scripts": {
    "benchmark:skills": "bun scripts/run-skill-evals.ts",
    "test": "bash scripts/run-tests-portable.sh",
    "test:coverage": "bun test --coverage",
    "check:type": "node node_modules/typescript/bin/tsc --noEmit",
    "check:runtime-architecture": "node scripts/check-runtime-architecture.mjs",
    "check:mcp-compatibility": "node --loader ./src/runtime/shared/node-ts-loader.mjs scripts/check-mcp-compatibility.ts",
    "smoke:runtime-control-plane": "node --loader ./src/runtime/shared/node-ts-loader.mjs scripts/smoke-runtime-control-plane.ts",
    "smoke:runtime-recovery": "node --loader ./src/runtime/shared/node-ts-loader.mjs scripts/smoke-runtime-recovery.ts",
    "smoke:mcp-http-runtime": "node --loader ./src/runtime/shared/node-ts-loader.mjs scripts/smoke-mcp-http-runtime.ts",
    "check:ci": "bash scripts/check-ci.sh",
    "check:release": "bash scripts/check-npm-release.sh",
    "check:release-surface": "bash scripts/check-public-release-surface.sh",
    "check:public-export": "bun scripts/public-release.ts",
    "package:source-zip": "bash scripts/package-source-archive.sh",
    "check:release-published": "bash scripts/check-release-published.sh",
    "smoke:tarball-install": "bash scripts/check-tarball-install-smoke.sh",
    "check:brain-manifest": "repo-harness run check-brain-manifest",
    "check:context-files": "repo-harness run check-context-files",
    "check:deploy-sql": "repo-harness run check-deploy-sql-order",
    "check:architecture-sync": "repo-harness run check-architecture-sync",
    "check:task-sync": "repo-harness run check-task-sync",
    "check:task-workflow": "repo-harness run check-task-workflow --strict",
    "controller:start": "bash scripts/controller-runtime.sh start",
    "controller:stop": "bash scripts/controller-runtime.sh stop",
    "controller:status": "bash scripts/controller-runtime.sh status",
    "controller:restart": "bash scripts/controller-runtime.sh restart",
    "controller:logs": "bash scripts/controller-runtime.sh logs",
    "prepublishOnly": "bash scripts/check-npm-release.sh",
    "sync:brain-docs": "repo-harness run sync-brain-docs --all",
    "sync:codex-installed": "bash scripts/sync-codex-installed-copies.sh",
    "check:controller-v8": "bash scripts/verify-controller-v8.sh",
    "repo:registry": "bun src/cli/v81-entry.ts repo",
    "repo:rollout": "bash scripts/rollout-all-registered-repos.sh",
    "smoke:schedule-engine": "node --loader ./src/runtime/shared/node-ts-loader.mjs scripts/smoke-schedule-engine.ts",
    "smoke:supervised-automation": "node --loader ./src/runtime/shared/node-ts-loader.mjs scripts/smoke-chatgpt-supervised-automation.ts",
    "check:env": "node scripts/check-runtime-env.mjs",
    "test:bun": "bun test",
    "test:node-smoke": "node --test tests/node/*.test.mjs",
    "check:ci:portable": "REPO_HARNESS_ALLOW_NODE_ONLY=1 bash scripts/check-ci.sh"
  },
  "devDependencies": {
    "@colbymchenry/codegraph": "1.0.1",
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "playwright": "^1.54.1"
  },
  "packageManager": "npm@10.0.0"
}
