FROM node:22-bookworm-slim

ARG BUN_VERSION=1.2.22
ENV BUN_INSTALL=/opt/bun
ENV PATH="/opt/bun/bin:${PATH}"
WORKDIR /workspace

RUN apt-get update \
  && apt-get install -y --no-install-recommends bash ca-certificates curl git openssh-client unzip \
  && rm -rf /var/lib/apt/lists/* \
  && curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}" \
  && bun --version \
  && node --version \
  && npm --version

COPY package.json package-lock.json* bun.lock* ./
RUN if [ -f bun.lock ]; then bun install --frozen-lockfile; else npm install --ignore-scripts --no-audit --no-fund; fi

COPY . .
CMD ["bash", "scripts/check-ci.sh"]
