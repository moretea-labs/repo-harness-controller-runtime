diff --git a/tests/runtime/plugin-direct-read.test.ts b/tests/runtime/plugin-direct-read.test.ts
new file mode 100644
index 0000000..0000000
--- /dev/null
+++ b/tests/runtime/plugin-direct-read.test.ts
@@ -0,0 +1,70 @@
+import { describe, expect, test } from 'bun:test';
+import { mkdtempSync, rmSync } from 'fs';
+import { tmpdir } from 'os';
+import { join } from 'path';
+import {
+  controllerPluginRepository,
+  executeAssistantPluginReadDirect,
+  getAssistantPluginManifest,
+} from '../../src/runtime/plugins/store';
+
+describe('plugin direct read plane', () => {
+  test('executes bounded local_system reads without creating a durable job', async () => {
+    const controllerHome = mkdtempSync(join(tmpdir(), 'repo-harness-direct-read-'));
+    try {
+      const repository = controllerPluginRepository(controllerHome);
+      const manifest = getAssistantPluginManifest(controllerHome, repository, 'local_system');
+      const action = manifest.actions.find((entry) => entry.actionId === 'list_directory');
+      expect(action?.readOnly).toBe(true);
+      expect(action?.risk).toBe('readonly');
+      expect(action?.confirmation).toBe('none');
+
+      // Invalid target is sufficient to prove the direct adapter path is used:
+      // it fails with a local-system validation error rather than returning a Job.
+      await expect(executeAssistantPluginReadDirect(controllerHome, repository, {
+        pluginId: 'local_system',
+        actionId: 'list_directory',
+        requestId: 'direct-read-test',
+        args: { target_key: 'missing-target', path: '.' },
+        origin: { surface: 'mcp', actor: 'test', correlationId: 'direct-read-test' },
+      })).rejects.toThrow();
+    } finally {
+      rmSync(controllerHome, { recursive: true, force: true });
+    }
+  });
+
+  test('rejects non-readonly actions from the direct plane', async () => {
+    const controllerHome = mkdtempSync(join(tmpdir(), 'repo-harness-direct-read-deny-'));
+    try {
+      const repository = controllerPluginRepository(controllerHome);
+      const manifest = getAssistantPluginManifest(controllerHome, repository, 'local_system');
+      const mutating = manifest.actions.find((entry) => !entry.readOnly);
+      if (!mutating) return;
+      await expect(executeAssistantPluginReadDirect(controllerHome, repository, {
+        pluginId: 'local_system',
+        actionId: mutating.actionId,
+        requestId: 'direct-read-deny-test',
+        args: {},
+        origin: { surface: 'mcp', actor: 'test', correlationId: 'direct-read-deny-test' },
+      })).rejects.toThrow('PLUGIN_DIRECT_READ_NOT_ALLOWED');
+    } finally {
+      rmSync(controllerHome, { recursive: true, force: true });
+    }
+  });
+});
